<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- La app solo usa cifrado estándar (HTTPS/TLS) → exenta. Evita el
		     prompt de "export compliance" en cada subida a TestFlight. -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>Promofy</string>
		<!-- Google Sign-In (iOS): client id de iOS del GoogleService-Info.plist -->
		<key>GIDClientID</key>
		<string>612781804475-5ouer3rm0f090i8jbr8uqp8c1nrm99i6.apps.googleusercontent.com</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>Promofy</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!-- ── Permisos ─────────────────────────────────────────────────────── -->
		<key>NSCameraUsageDescription</key>
		<string>Promofy necesita acceso a la cámara para escanear códigos QR de clientes.</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>Promofy necesita acceso a tu galería para subir fotos de tu negocio.</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>Promofy necesita permiso para guardar imágenes en tu galería.</string>
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>Promofy usa tu ubicación para mostrarte promociones cerca de ti ordenadas por distancia.</string>
		<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
		<string>Promofy usa tu ubicación para mostrarte promociones cerca de ti ordenadas por distancia.</string>
		<!-- ── Notificaciones push en background (Firebase Messaging) ────────── -->
		<key>UIBackgroundModes</key>
		<array>
			<string>fetch</string>
			<string>remote-notification</string>
		</array>
		<!-- ── Interface ─────────────────────────────────────────────────────── -->
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<!-- Storyboard principal: monta el FlutterViewController como root.
		     SIN esta clave la ventana se queda sin rootViewController y la app
		     se ve NEGRA tras el splash. -->
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UIStatusBarHidden</key>
		<false/>
		<!-- ── URL Schemes ───────────────────────────────────────────────────── -->
		<!-- url_launcher: permite abrir WhatsApp desde la app -->
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>whatsapp</string>
		</array>
		<key>CFBundleURLTypes</key>
		<array>
			<!-- Deep links: promofy:// (redireccionamiento desde promofy.fun) -->
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLName</key>
				<string>mx.promofy.app</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>promofy</string>
				</array>
			</dict>
			<!-- Google Sign-In: REVERSED_CLIENT_ID del GoogleService-Info.plist -->
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>com.googleusercontent.apps.612781804475-5ouer3rm0f090i8jbr8uqp8c1nrm99i6</string>
				</array>
			</dict>
		</array>
	</dict>
</plist>
